<Window x:Class="RegistryToJson.Gui.ZoomWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Height="780"
        Width="1180"
        MinHeight="560"
        MinWidth="840"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Background="{StaticResource PanelBackgroundBrush}"
                BorderBrush="{StaticResource PanelBorderBrush}"
                BorderThickness="1"
                CornerRadius="18"
                Padding="18"
                Margin="0,0,0,16">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock x:Name="WindowTitleTextBlock"
                               Text="放大查看"
                               FontFamily="Bahnschrift SemiCondensed"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="{StaticResource AccentBrush}" />
                    <TextBlock x:Name="WindowDescriptionTextBlock"
                               Margin="0,6,0,0"
                               Text="查看当前选中配置的详细内容。"
                               Foreground="{StaticResource MutedTextBrush}"
                               FontSize="14"
                               TextWrapping="Wrap" />
                </StackPanel>

                <TextBlock x:Name="WindowMetaTextBlock"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource MutedTextBrush}"
                           TextWrapping="Wrap"
                           TextAlignment="Right" />
            </DockPanel>
        </Border>

        <ContentControl Grid.Row="1" x:Name="ZoomContentHost" />
    </Grid>
</Window>
